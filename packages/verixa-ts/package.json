{
  "name": "@verixa/ts",
  "version": "0.1.0",
  "private": true,
  "description": "Verixa shared TypeScript library (cross-cutting types, constants, helpers)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compliance-language": {
      "types": "./dist/compliance-language.d.ts",
      "import": "./dist/compliance-language.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'lint placeholder (CP-2.4 wires ESLint)'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
