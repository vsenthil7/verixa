{
  "components": {
    "schemas": {
      "AgentRegisterRequest": {
        "additionalProperties": false,
        "description": "Register an agent (an operational entity acting under a workflow).\n\n``spiffe_id`` is the agent's SPIFFE identity in dev mode (Phase-0\nbypasses SPIFFE verification; the field is recorded for forward\ncompatibility).",
        "properties": {
          "description": {
            "default": "",
            "maxLength": 2000,
            "title": "Description",
            "type": "string"
          },
          "role": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Role",
            "type": "string"
          },
          "spiffe_id": {
            "maxLength": 512,
            "minLength": 1,
            "title": "Spiffe Id",
            "type": "string"
          },
          "workflow_id": {
            "format": "uuid",
            "title": "Workflow Id",
            "type": "string"
          }
        },
        "required": [
          "workflow_id",
          "spiffe_id",
          "role"
        ],
        "title": "AgentRegisterRequest",
        "type": "object"
      },
      "DossierGenerateRequest": {
        "additionalProperties": false,
        "description": "Generate a dossier for a previously-decided audit_id.",
        "properties": {
          "action_summary": {
            "default": "",
            "description": "Auditor-readable summary of the action the dossier covers. Empty defaults to a system-generated summary.",
            "maxLength": 2000,
            "title": "Action Summary",
            "type": "string"
          },
          "audit_id": {
            "format": "uuid",
            "title": "Audit Id",
            "type": "string"
          }
        },
        "required": [
          "audit_id"
        ],
        "title": "DossierGenerateRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ReplayRequest": {
        "additionalProperties": false,
        "description": "Request a previously-snapshotted decision by audit_id.",
        "properties": {
          "audit_id": {
            "format": "uuid",
            "title": "Audit Id",
            "type": "string"
          }
        },
        "required": [
          "audit_id"
        ],
        "title": "ReplayRequest",
        "type": "object"
      },
      "ToolRegisterRequest": {
        "additionalProperties": false,
        "description": "Register a tool the agent may invoke (subject to firewall).",
        "properties": {
          "allowed_workflow_ids": {
            "description": "Empty list means 'any workflow'. Non-empty restricts the tool to the listed workflows.",
            "items": {
              "format": "uuid",
              "type": "string"
            },
            "title": "Allowed Workflow Ids",
            "type": "array"
          },
          "description": {
            "default": "",
            "maxLength": 2000,
            "title": "Description",
            "type": "string"
          },
          "is_active": {
            "default": true,
            "title": "Is Active",
            "type": "boolean"
          },
          "name": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "title": "ToolRegisterRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "WebhookSubscribeRequest": {
        "additionalProperties": false,
        "description": "POST /v1/control/webhooks/subscriptions -- create a subscription.\n\ntenant_id is the customer's tenant; url is the HTTPS endpoint we'll\nPOST to on each matching event; event_types is the non-empty subset\nof the allowlist the subscription wants to receive; signing_key_id\nis the Vault-tracked key the dispatcher will sign deliveries with.",
        "properties": {
          "event_types": {
            "items": {
              "type": "string"
            },
            "maxItems": 32,
            "minItems": 1,
            "title": "Event Types",
            "type": "array"
          },
          "signing_key_id": {
            "maxLength": 128,
            "minLength": 12,
            "title": "Signing Key Id",
            "type": "string"
          },
          "tenant_id": {
            "format": "uuid",
            "title": "Tenant Id",
            "type": "string"
          },
          "url": {
            "maxLength": 2048,
            "minLength": 12,
            "title": "Url",
            "type": "string"
          }
        },
        "required": [
          "tenant_id",
          "url",
          "event_types",
          "signing_key_id"
        ],
        "title": "WebhookSubscribeRequest",
        "type": "object"
      },
      "WorkflowRegisterRequest": {
        "additionalProperties": false,
        "description": "Register a new workflow under the calling tenant.",
        "properties": {
          "description": {
            "default": "",
            "maxLength": 2000,
            "title": "Description",
            "type": "string"
          },
          "name": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "risk_threshold_escalate": {
            "default": 0.5,
            "description": "Above this risk score, the workflow's decisions escalate to triad review.",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Risk Threshold Escalate",
            "type": "number"
          },
          "sector": {
            "default": "generic",
            "description": "Industry tag, e.g. 'financial-services', 'healthcare'.",
            "maxLength": 64,
            "title": "Sector",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "title": "WorkflowRegisterRequest",
        "type": "object"
      }
    }
  },
  "info": {
