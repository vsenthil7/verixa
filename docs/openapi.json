    "/v1/control/policy/bundles/{name}": {
      "get": {
        "description": "Fetch a signed bundle as gzipped tar.\n\nReturns 200 with tar.gz body + ETag header on first fetch;\n304 if If-None-Match matches the current ETag (OPA cache hit).\nReturns 400 / 404 / 503 with JSON body for failure modes.",
        "operationId": "bundles_fetch_v1_control_policy_bundles__name__get",
        "parameters": [
          {
            "in": "path",
            "name": "name",
            "required": true,
            "schema": {
              "title": "Name",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "if-none-match",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "If-None-Match"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Bundles Fetch",
        "tags": [
          "control-plane"
        ]
      }
    },
