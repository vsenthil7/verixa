{
  "name": "@verixa/control-plane-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Verixa Control Plane UI (Next.js 14)",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next coverage .turbo node_modules/.cache test-results playwright-report"
  },
  "dependencies": {
    "@verixa/ts": "workspace:*",
    "next": "^14.2.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
