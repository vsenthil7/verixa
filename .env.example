# =============================================================================
# Verixa — environment variables (example)
# Copy to `.env` and adjust. `.env` is gitignored.
# =============================================================================

# --- Postgres ---
POSTGRES_USER=verixa
POSTGRES_PASSWORD=verixa_dev_password
POSTGRES_DB=verixa
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://verixa:verixa_dev_password@localhost:5432/verixa

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- OPA ---
OPA_URL=http://localhost:8181

# --- Vault (DEV MODE; never use in prod) ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=verixa-dev-root-token

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=verixa
MINIO_SECRET_KEY=verixa_dev_password
MINIO_BUCKET_REPLAY=verixa-replay
MINIO_USE_SSL=false

# --- Prometheus ---
PROMETHEUS_URL=http://localhost:9090

# --- Verixa Runtime Gateway ---
VERIXA_RUNTIME_HOST=0.0.0.0
VERIXA_RUNTIME_PORT=8000
VERIXA_RUNTIME_API_KEY=verixa-dev-runtime-key-CHANGE-ME

# --- Verixa Control Plane API ---
VERIXA_CONTROL_PLANE_HOST=0.0.0.0
VERIXA_CONTROL_PLANE_PORT=8001

# --- Triad reviewer config (path to YAML) ---
VERIXA_REVIEWERS_CONFIG=config/reviewers.yaml

# --- Logging ---
VERIXA_LOG_LEVEL=INFO
VERIXA_LOG_FORMAT=json

# --- HF Inference Endpoints fallback (only used when triad backend = hf-inference) ---
HF_TOKEN=
