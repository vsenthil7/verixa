# Verixa -- Environment Variables
# Copy to .env and fill in values. NEVER commit .env.
# Convention mirrors Auditex (sister project) so a single dev .env can
# back both repositories.

# ---------------------------------------------------------------------------
# Verixa Runtime Gateway -- API key store
# ---------------------------------------------------------------------------
# Format: comma-separated `tenant_uuid:api_key` pairs.
# Each value is read by verixa_runtime.gateway.auth.parse_api_key_env.
# Phase 0 -- env-var driven; Phase 1 swaps to verixa_tenancy.api_keys table.
VERIXA_API_KEYS=00000000-0000-0000-0000-000000000001:dev-tenant-key-1,00000000-0000-0000-0000-000000000002:dev-tenant-key-2

# Where the runtime forwards /v1/chat/completions traffic.
# Phase 0 hackathon: live AMD MI300X droplet running vLLM-on-ROCm.
VERIXA_VLLM_BASE_URL=http://165.245.133.120:8000

# Build identifier reported by GET /version. CI sets this to the git sha.
VERIXA_BUILD_ID=dev

# ---------------------------------------------------------------------------
# Model provider keys (shared with Auditex naming; pulled into Verixa for
# fallback / non-MI300X environments and future Triad-Review reviewer slots
# when running outside the droplet).
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=your_openai_api_key_here
GPT4O_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Postgres (control-plane DB; Phase 0 dev = local docker-compose service)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://verixa:verixa_dev_password@localhost:5432/verixa
POSTGRES_USER=verixa
POSTGRES_PASSWORD=verixa_dev_password
POSTGRES_DB=verixa

# ---------------------------------------------------------------------------
# Redis + object store
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# MinIO is wired in CP-12 (replay vault); placeholder here so the env
# shape is stable across CPs.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=verixa_dev_minio
MINIO_SECRET_KEY=verixa_dev_minio_secret

# ---------------------------------------------------------------------------
# Crypto + signing
# ---------------------------------------------------------------------------
JWT_SECRET=change_in_production
API_KEY_SALT=change_in_production

# ---------------------------------------------------------------------------
# Service config
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000
RATE_LIMIT_PER_MINUTE=600
